+#include "components/psyops/psyops_switches.h"
+
+namespace switches {
+
+// Names the psyop this Chromium session is bound to. String value.
+// Ignored when --x-app is also present (--x-app takes precedence).
+const char kPsyop[] = "psyop";
+
+// Marks this Chromium session as the master X-app (root account) session.
+// Boolean flag.
+const char kXApp[] = "x-app";
+
+// Base directory holding all psychological-operations state for this host
+// (matches `cfg.base_dir()` on the launcher side). Required at launch.
+const char kConfigBaseDir[] = "config-base-dir";
+
+}  // namespace switches
