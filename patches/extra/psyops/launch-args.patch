--- a/chrome/app/chrome_main_delegate.cc
+++ b/chrome/app/chrome_main_delegate.cc
@@ -76,6 +76,7 @@
 #include "components/memory_system/initializer.h"
 #include "components/memory_system/parameters.h"
 #include "components/metrics/persistent_histograms.h"
+#include "components/psyops/psyops_switches.h"
 #include "components/sampling_profiler/thread_profiler.h"
 #include "components/startup_metric_utils/common/startup_metric_utils.h"
 #include "components/variations/service/variations_network_clock.h"
@@ -1057,6 +1058,70 @@ std::optional<int> ChromeMainDelegate::BasicStartupComplete() {
   const base::CommandLine& command_line =
       *base::CommandLine::ForCurrentProcess();

+  // psyops launch arg validation and per-session state redirection:
+  // the browser process must be invoked with --config-base-dir AND at
+  // least one of --psyop / --x-app. Subprocesses inherit the command
+  // line, so this is a one-shot gate at the browser-process startup
+  // boundary. After validating, --user-data-dir is forced to a
+  // per-session subdirectory so every byte of state (cookies, cache,
+  // history, extensions, ...) nests under one path we control. If
+  // both --x-app and --psyop are set, --x-app wins.
+  if (!command_line.HasSwitch(switches::kProcessType)) {
+    if (!command_line.HasSwitch(switches::kConfigBaseDir)) {
+      LOG(ERROR) << "--" << switches::kConfigBaseDir << " is required";
+      return 1;
+    }
+    if (!command_line.HasSwitch(switches::kPsyop) &&
+        !command_line.HasSwitch(switches::kXApp)) {
+      LOG(ERROR) << "one of --" << switches::kPsyop
+                 << " or --" << switches::kXApp << " must be specified";
+      return 1;
+    }
+
+    base::FilePath target_dir =
+        command_line.GetSwitchValuePath(switches::kConfigBaseDir)
+            .Append(FILE_PATH_LITERAL("plugins"))
+            .Append(FILE_PATH_LITERAL("psychological-operations"))
+            .Append(FILE_PATH_LITERAL("chromium"));
+    if (command_line.HasSwitch(switches::kXApp)) {
+      target_dir = target_dir.Append(FILE_PATH_LITERAL("x-app"));
+    } else {
+      target_dir =
+          target_dir.Append(FILE_PATH_LITERAL("psyops"))
+              .AppendASCII(
+                  command_line.GetSwitchValueASCII(switches::kPsyop));
+    }
+    base::CommandLine::ForCurrentProcess()->AppendSwitchPath(
+        switches::kUserDataDir, target_dir);
+
+    // Three Chromium dirs deliberately ignore --user-data-dir (they're
+    // computed from GetDefaultUserDataDirectory() because they're
+    // initialized before command-line parsing). Override them via
+    // PathService so every byte of state stays under target_dir.
+    base::PathService::OverrideAndCreateIfNeeded(
+        chrome::DIR_CRASH_DUMPS,
+        target_dir.Append(FILE_PATH_LITERAL("Crashpad")),
+        /*is_absolute=*/false, /*create=*/true);
+#if BUILDFLAG(IS_WIN)
+    base::PathService::OverrideAndCreateIfNeeded(
+        chrome::DIR_WATCHER_DATA,
+        target_dir.Append(FILE_PATH_LITERAL("Diagnostics")),
+        /*is_absolute=*/false, /*create=*/true);
+    base::PathService::OverrideAndCreateIfNeeded(
+        chrome::DIR_ROAMING_USER_DATA,
+        target_dir.Append(FILE_PATH_LITERAL("Roaming")),
+        /*is_absolute=*/false, /*create=*/true);
+#endif
+
+    // Auto-open the X developer console for the master X-app session,
+    // but only if the launcher didn't already pass a URL.
+    if (command_line.HasSwitch(switches::kXApp) &&
+        command_line.GetArgs().empty()) {
+      base::CommandLine::ForCurrentProcess()->AppendArg(
+          "https://console.x.ai");
+    }
+  }
+
   // Only allow disabling web security via the command-line flag if the user has
   // specified a distinct profile directory. This still enables tests to disable
   // web security by setting the kWebKitWebSecurityEnabled pref directly.
