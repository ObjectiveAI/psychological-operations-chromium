+#ifndef COMPONENTS_PSYOPS_X_APP_POINTER_H_
+#define COMPONENTS_PSYOPS_X_APP_POINTER_H_
+
+namespace psyops {
+
+// Starts the x-app sign-in pointer feature: on each navigation in any
+// browser tab, injects HandPointer.js + a bootstrap that finds the
+// "Sign in" link and points at it. UI-thread only; idempotent.
+void StartXAppSignInPointer();
+
+}  // namespace psyops
+
+#endif  // COMPONENTS_PSYOPS_X_APP_POINTER_H_
