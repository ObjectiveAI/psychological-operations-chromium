# Point the HandPointer overlay at the "Sign in" link in --x-app mode.
#
# Adds components/psyops/x_app_pointer.{h,cc}. When chromium is launched
# with --x-app, on every committed primary-main-frame navigation in any
# browser tab, we inject:
#   1. psyops::HandPointerJs() (the baked-in library, attaches to
#      globalThis.psyops.HandPointer in our isolated world).
#   2. A small bootstrap that hides any prior pointer, finds
#      a[href*="accounts.x.ai/sign-in"], and creates a 👉 pointer
#      with helper text on it.
#
# Bootstrap is a no-op on pages without the selector (e.g.
# accounts.x.ai's actual login form), so navigating away cleans up
# the pointer automatically.

--- /dev/null
+++ b/components/psyops/x_app_pointer.h
@@ -0,0 +1,17 @@
