+#ifndef COMPONENTS_PSYOPS_STDIN_IO_H_
+#define COMPONENTS_PSYOPS_STDIN_IO_H_
+
+namespace psyops {
+
+// Starts a background thread that reads JSON-Lines requests from stdin
+// and dispatches them to UI-thread handlers. Responses are JSONL on
+// stdout. Idempotent: safe to call once early in browser-process startup.
+//
+// Currently supported request types:
+//   {"type":"html"} -> {"type":"html","html":"..."}
+//                  or {"type":"html","error":"..."}
+void StartStdinIo();
+
+}  // namespace psyops
+
+#endif  // COMPONENTS_PSYOPS_STDIN_IO_H_
