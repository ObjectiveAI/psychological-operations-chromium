# Add a JSON-Lines stdin/stdout dev API to the chromium browser process.
#
# A dedicated background thread reads one JSON object per line from
# stdin, parses it, and dispatches to UI-thread handlers. Each handler
# writes a JSON response line to stdout under a mutex (so concurrent
# in-flight requests don't interleave).
#
# Initial dispatch table:
#   {"type":"html"} -> {"type":"html","html":"..."} or
#                     {"type":"html","error":"..."}
#
# The reader thread starts from ChromeMainDelegate::BasicStartupComplete
# inside the existing browser-process guard (added by launch-args.patch).
# Unknown request types are dropped with VLOG(1).

--- /dev/null
+++ b/components/psyops/stdin_io.h
@@ -0,0 +1,20 @@
